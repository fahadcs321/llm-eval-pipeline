# Copy to .env and fill in. NEVER commit .env to git.

# ── Judge LLM (scores the outputs) ───────────────────────────────────────────
# Provider: groq (default, free) | openai | google | anthropic
JUDGE_PROVIDER=groq
# Optional: pin a specific model. Defaults per provider if unset.
# JUDGE_MODEL=llama-3.3-70b-versatile

# ── Provider API keys (only the one matching JUDGE_PROVIDER is required) ──────
GROQ_API_KEY=your_groq_key_here
# OPENAI_API_KEY=your_openai_key_here
# GOOGLE_API_KEY=your_google_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── System under test (Project 1, Self-Healing RAG) ──────────────────────────
# Where Project 1 lives. Defaults to ../self_healing_rag relative to this repo.
# SELF_HEALING_RAG_PATH=/abs/path/to/self_healing_rag
LLM_MODEL=llama-3.3-70b-versatile

# ── Cost tracking (LiteLLM) ──────────────────────────────────────────────────
COST_MODEL=groq/llama-3.3-70b-versatile

# ── Observability (all optional — pipeline no-ops cleanly if unset) ──────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
GRAFANA_URL=http://localhost:3001
GRAFANA_API_KEY=
SLACK_WEBHOOK_URL=
